  "keyFeatures": [
    "CUIS and CUFD code management (individual and bulk)",
    "NIT validation and certificate revocation handling",
    "Catalog synchronization (activities, parameters, products)",
    "Point of sale operations and significant events",
    "Invoice reception with XML signing and compression",
    "Invoice cancellation support",
    "CUF generation and XML digital signatures",
    "Builder pattern API for type-safe request construction"
  ],
  "publicApiSurface": [
    "siat.New() - Initialize SIAT client",
    "Codigos.SolicitudCuis() - Request CUIS code",
    "Codigos.SolicitudCufd() - Request CUFD code",
    "Codigos.VerificarNit() - Verify NIT number",
    "Sincronizacion.SincronizarActividades() - Sync activities catalog",
    "Sincronizacion.SincronizarParametrica*() - Sync parametric catalogs",
    "Operaciones.RegistroPuntoVenta() - Register point of sale",
    "Operaciones.CierrePuntoVenta() - Close point of sale",
    "Operaciones.RegistroEventoSignificativo() - Register significant event",
    "CompraVenta.RecepcionFactura() - Submit invoice",
    "CompraVenta.AnulacionFactura() - Cancel invoice",
    "CompraVenta.GenerarCUF() - Generate unique invoice code",
    "CompraVenta.SignXML() - Sign XML document",
    "models.Codigos.New*Request() - Builder for Codigos requests",
    "models.Sincronizacion.New*Request() - Builder for Sincronizacion requests",
    "models.Operaciones.New*Request() - Builder for Operaciones requests",
    "models.CompraVenta.New*() - Builders for invoice components"
  ]
}
